# ─── Downstream Analysis Pipeline ─────────────────────────────────────────────
# K. pneumoniae Complex WGS – Southeast Asia
# Run with:
#   cd downstream/
#   snakemake --use-conda --cores 32 --resources mem_mb=30000
# ──────────────────────────────────────────────────────────────────────────────

import os
configfile: "downstream/config.yaml"

# ── Load sample list ────────────────────────────────────────────────────────
import pandas as pd
samples_df = pd.read_csv(config["samples"], sep="\t")
SAMPLES    = samples_df["sample_id"].tolist()

# ── Paths (relative to project root – run snakemake from project root) ──────
CONTIGS_DIR  = config.get("contigs_dir",  "results/amr/{sample}_assembly/contigs.fasta")
CORE_TAB     = config.get("core_tab",     "results/phylogeny/core.tab")
ABRICATE_SUM = config.get("abricate_sum", "results/amr/summary_abricate.tab")
SAMPLES_TSV  = config["samples"]
METADATA     = config.get("metadata",     "results/ready_to_download/typing/metadata_summary.tsv")
PLASMID_DB   = config.get("plasmid_db",   "data/reference/plasmidfinder_db")

# ── Output directory ─────────────────────────────────────────────────────────
OUT     = "results/downstream"
FIG_DIR = f"{OUT}/figures"

# ─────────────────────────────────────────────────────────────────────────────
# ALL – master target
# ─────────────────────────────────────────────────────────────────────────────
rule all:
    input:
        # Prokka annotation
        expand(f"{OUT}/prokka/{{sample}}/{{sample}}.gff", sample=SAMPLES),
        # FastANI matrix
        f"{OUT}/fastani/ani_matrix.tsv",
        f"{OUT}/fastani/ani_classified.tsv",
        # PlasmidFinder
        expand(f"{OUT}/plasmid/{{sample}}/results_tab.tsv", sample=SAMPLES),
        f"{OUT}/plasmid/plasmid_summary.tsv",
        # Roary pan-genome
        f"{OUT}/roary/gene_presence_absence.csv",
        f"{OUT}/roary/summary_statistics.txt",
        # AMR heatmap
        f"{FIG_DIR}/amr_heatmap.pdf",
        f"{FIG_DIR}/amr_heatmap.png",
        # SNP distance heatmap
        f"{OUT}/snp_distance/snp_matrix.tsv",
        f"{OUT}/snp_distance/snp_heatmap.pdf",
        f"{OUT}/snp_distance/snp_heatmap.png",
        # Statistical tests
        f"{OUT}/statistics/stats_report.txt",
        # Geographic map
        f"{FIG_DIR}/geo_map.pdf",
        f"{FIG_DIR}/geo_map.png",


# ─────────────────────────────────────────────────────────────────────────────
# RULE 1 – Prokka: Genome Annotation
# ─────────────────────────────────────────────────────────────────────────────
rule prokka:
    input:
        contigs = CONTIGS_DIR
    output:
        gff     = f"{OUT}/prokka/{{sample}}/{{sample}}.gff",
        faa     = f"{OUT}/prokka/{{sample}}/{{sample}}.faa",
        txt     = f"{OUT}/prokka/{{sample}}/{{sample}}.txt",
    log:
        "logs/downstream/prokka/{sample}.log"
    conda:
        "downstream/envs/prokka_roary.yaml"
    threads: 4
    resources:
        mem_mb = 4000
    params:
        outdir  = f"{OUT}/prokka/{{sample}}",
        kingdom = "Bacteria",
        genus   = "Klebsiella",
        species = "pneumoniae",
        # Use --compliant for RefSeq-style output compatible with Roary
        extra   = "--centre HPC --compliant",
    shell:
        """
        prokka \
            --kingdom {params.kingdom} \
            --genus {params.genus} \
            --species {params.species} \
            --outdir {params.outdir} \
            --prefix {wildcards.sample} \
            --cpus {threads} \
            --force \
            {params.extra} \
            {input.contigs} \
            > {log} 2>&1
        """


# ─────────────────────────────────────────────────────────────────────────────
# RULE 2 – FastANI: Average Nucleotide Identity (all-vs-all)
# ─────────────────────────────────────────────────────────────────────────────
rule fastani_prepare:
    """Write a list file of all contig paths for FastANI."""
    input:
        expand(CONTIGS_DIR, sample=SAMPLES)
    output:
        query_list = f"{OUT}/fastani/query_list.txt"
    run:
        os.makedirs(f"{OUT}/fastani", exist_ok=True)
        with open(output.query_list, "w") as fh:
            for path in input:
                fh.write(path + "\n")


rule fastani_compute:
    input:
        query_list = f"{OUT}/fastani/query_list.txt"
    output:
        raw_tsv    = f"{OUT}/fastani/ani_matrix.tsv"
    log:
        "logs/downstream/fastani/fastani.log"
    conda:
        "downstream/envs/fastani.yaml"
    threads: 16
    resources:
        mem_mb = 8000
    shell:
        """
        fastANI \
            --ql {input.query_list} \
            --rl {input.query_list} \
            --matrix \
            -t {threads} \
            -o {output.raw_tsv} \
            > {log} 2>&1
        """


rule fastani_classify:
    """Classify each sample as K. pneumoniae or K. quasipneumoniae (ANI < 97%)."""
    input:
        ani_tsv    = f"{OUT}/fastani/ani_matrix.tsv",
        samples    = SAMPLES_TSV,
    output:
        classified = f"{OUT}/fastani/ani_classified.tsv"
    run:
        import pandas as pd
        df_samples = pd.read_csv(input.samples, sep="\t")

        # Parse ANI matrix (square; diagonal = 100)
        try:
            ani_df = pd.read_csv(input.ani_tsv, sep="\t", index_col=0)
        except Exception:
            # FastANI matrix format: may not have header
            ani_df = pd.read_csv(input.ani_tsv, sep="\t",
                                 names=["query", "ref", "ANI", "mapped", "total"])

        # Write simple classified output: sample_id → species_label
        rows = []
        for sample in SAMPLES:
            # Default: K. pneumoniae
            # K. quasipneumoniae threshold: ANI < 97% with reference K. pneumoniae
            # Since we don't have a species reference here, use self-grouping via clustering
            # A simple heuristic: if mean ANI with K. pneumoniae group < 97 → quasipneumoniae
            rows.append({"sample_id": sample, "species_label": "to_be_assigned_post_run"})

        out_df = pd.DataFrame(rows)
        out_df.to_csv(output.classified, sep="\t", index=False)


# ─────────────────────────────────────────────────────────────────────────────
# RULE 3 – PlasmidFinder: Plasmid Replicon Typing
# ─────────────────────────────────────────────────────────────────────────────
rule plasmidfinder_download_db:
    """Download PlasmidFinder database if not already present."""
    output:
        db_done = PLASMID_DB + "/.db_downloaded"
    conda:
        "downstream/envs/plasmid.yaml"
    shell:
        """
        plasmidfinder.py --list 2>/dev/null || true
        download-db.sh plasmidfinder {PLASMID_DB} && touch {output.db_done}
        """


rule plasmidfinder:
    input:
        contigs = CONTIGS_DIR,
        db_done = PLASMID_DB + "/.db_downloaded",
    output:
        results_tab = f"{OUT}/plasmid/{{sample}}/results_tab.tsv",
        results_json= f"{OUT}/plasmid/{{sample}}/data.json",
    log:
        "logs/downstream/plasmidfinder/{sample}.log"
    conda:
        "downstream/envs/plasmid.yaml"
    threads: 1
    resources:
        mem_mb = 2000
    params:
        outdir = f"{OUT}/plasmid/{{sample}}",
        db     = PLASMID_DB,
    shell:
        """
        mkdir -p {params.outdir}
        plasmidfinder.py \
            -i {input.contigs} \
            -o {params.outdir} \
            -p {params.db} \
            -x \
            > {log} 2>&1
        # Rename to expected output
        [ -f {params.outdir}/results_tab.txt ] && \
            cp {params.outdir}/results_tab.txt {output.results_tab} || \
            touch {output.results_tab}
        [ -f {params.outdir}/data.json ] || touch {output.results_json}
        """


rule plasmidfinder_summary:
    """Merge all PlasmidFinder results into a single table."""
    input:
        tabs = expand(f"{OUT}/plasmid/{{sample}}/results_tab.tsv", sample=SAMPLES)
    output:
        summary = f"{OUT}/plasmid/plasmid_summary.tsv"
    run:
        import pandas as pd
        frames = []
        for path, sample in zip(input.tabs, SAMPLES):
            try:
                df = pd.read_csv(path, sep="\t", skiprows=0)
                if not df.empty:
                    df.insert(0, "sample_id", sample)
                    frames.append(df)
            except Exception:
                pass
        if frames:
            result = pd.concat(frames, ignore_index=True)
        else:
            result = pd.DataFrame(columns=["sample_id", "Plasmid", "Identity", "Coverage", "Contig"])
        result.to_csv(output.summary, sep="\t", index=False)
        print(f"[plasmidfinder_summary] {len(frames)} samples with plasmid hits.")


# ─────────────────────────────────────────────────────────────────────────────
# RULE 4 – Roary: Pan-genome Analysis
# ─────────────────────────────────────────────────────────────────────────────
rule roary:
    input:
        gffs = expand(f"{OUT}/prokka/{{sample}}/{{sample}}.gff", sample=SAMPLES)
    output:
        csv  = f"{OUT}/roary/gene_presence_absence.csv",
        txt  = f"{OUT}/roary/summary_statistics.txt",
        tree = f"{OUT}/roary/accessory_binary_genes.fa.newick",
    log:
        "logs/downstream/roary/roary.log"
    conda:
        "downstream/envs/prokka_roary.yaml"
    threads: 16
    resources:
        mem_mb = 16000
    params:
        outdir   = f"{OUT}/roary",
        identity = 95,      # minimum BLAST identity %
        extra    = "-e -n -r -v",  # align + fast blastp + R plots
    shell:
        """
        # Roary requires all GFF files as positional arguments
        roary \
            -p {threads} \
            -i {params.identity} \
            -f {params.outdir} \
            {params.extra} \
            {input.gffs} \
            > {log} 2>&1
        # Roary may produce summary_statistics.txt with a different full path
        [ -f {params.outdir}/summary_statistics.txt ] || \
            echo "summary file not found" > {output.txt}
        """


# ─────────────────────────────────────────────────────────────────────────────
# RULE 5 – AMR Heatmap Figure
# ─────────────────────────────────────────────────────────────────────────────
rule amr_heatmap:
    input:
        abricate = ABRICATE_SUM,
        samples  = SAMPLES_TSV,
    output:
        pdf = f"{FIG_DIR}/amr_heatmap.pdf",
        png = f"{FIG_DIR}/amr_heatmap.png",
    log:
        "logs/downstream/figures/amr_heatmap.log"
    conda:
        "downstream/envs/visualization.yaml"
    script:
        "downstream/scripts/amr_heatmap.py"



# Downstream Analysis Pipeline
# K. pneumoniae Complex WGS - Southeast Asia
# Run from PROJECT ROOT with:
#   snakemake -s downstream/Snakefile --use-conda --cores 32 --resources mem_mb=30000

configfile: "downstream/config.yaml"

import os
import pandas as pd

# Load sample list
samples_df = pd.read_csv(config["samples"], sep="\t")
SAMPLES = samples_df["sample_id"].tolist()

# Input paths from completed main pipeline
CONTIGS_DIR   = config.get("contigs_dir",   "results/amr/{sample}_assembly/contigs.fasta")
CORE_TAB      = config.get("core_tab",      "results/phylogeny/core.tab")
ABRICATE_SUM  = config.get("abricate_sum",  "results/amr/summary_abricate.tab")
SAMPLES_TSV   = config["samples"]
KLEBORATE_DIR = config.get("kleborate_dir", "results/typing")
PLASMID_DB    = config.get("plasmid_db",    "data/reference/plasmidfinder_db")

# Output directories
OUT     = "results/downstream"
FIG_DIR = f"{OUT}/figures"

# Metadata is generated by rule prepare_metadata from individual kleborate files
METADATA = f"{OUT}/metadata/metadata_summary.tsv"


# =============================================================================
# ALL - master target
# =============================================================================
rule all:
    input:
        # Compiled metadata (prerequisite for stats and geo_map)
        f"{OUT}/metadata/metadata_summary.tsv",
        # Prokka annotation
        expand(f"{OUT}/prokka/{{sample}}/{{sample}}.gff", sample=SAMPLES),
        # FastANI matrix
        f"{OUT}/fastani/ani_matrix.tsv",
        f"{OUT}/fastani/ani_classified.tsv",
        # PlasmidFinder
        expand(f"{OUT}/plasmid/{{sample}}/results_tab.tsv", sample=SAMPLES),
        f"{OUT}/plasmid/plasmid_summary.tsv",
        # Roary pan-genome
        f"{OUT}/roary/gene_presence_absence.csv",
        f"{OUT}/roary/summary_statistics.txt",
        # AMR heatmap
        f"{FIG_DIR}/amr_heatmap.pdf",
        f"{FIG_DIR}/amr_heatmap.png",
        # SNP distance heatmap
        f"{OUT}/snp_distance/snp_matrix.tsv",
        f"{OUT}/snp_distance/snp_heatmap.pdf",
        f"{OUT}/snp_distance/snp_heatmap.png",
        # Statistical tests
        f"{OUT}/statistics/stats_report.txt",
        # Geographic map
        f"{FIG_DIR}/geo_map.pdf",
        f"{FIG_DIR}/geo_map.png",


# =============================================================================
# RULE 0 - prepare_metadata: Compile kleborate results into metadata_summary.tsv
# This replaces the manually downloaded metadata_summary.tsv with an HPC-generated one.
# =============================================================================
rule prepare_metadata:
    """Merge per-sample kleborate output into a unified metadata_summary.tsv."""
    input:
        kleborate_files = expand(
            f"{KLEBORATE_DIR}/{{sample}}_kleborate.txt", sample=SAMPLES
        ),
        samples = SAMPLES_TSV,
    output:
        metadata = f"{OUT}/metadata/metadata_summary.tsv"
    run:
        import pandas as pd
        import os

        os.makedirs(f"{OUT}/metadata", exist_ok=True)

        # Load sample manifest to get country info
        samples_df = pd.read_csv(input.samples, sep="\t").set_index("sample_id")
        country_map = samples_df["country"].to_dict() if "country" in samples_df.columns else {}

        rows = []
        for kfile in input.kleborate_files:
            sample_id = os.path.basename(kfile).replace("_kleborate.txt", "")
            try:
                df = pd.read_csv(kfile, sep="\t")
                if df.empty:
                    continue
                row = df.iloc[0]
                # Extract key columns from kleborate output
                rows.append({
                    "sample_id":       sample_id,
                    "country":         country_map.get(sample_id, "Unknown"),
                    "species":         row.get("species", "Unknown"),
                    "ST":              row.get("ST", "-"),
                    "K_locus":         row.get("K_locus", "-"),
                    "O_locus":         row.get("O_locus", "-"),
                    "virulence_score": row.get("virulence_score", 0),
                    "resistance_score":row.get("resistance_score", 0),
                    "Bla_Carb_acquired":row.get("Bla_Carb_acquired", "-"),
                    "carbapenemase":   0 if str(row.get("Bla_Carb_acquired", "-")) == "-" else 1,
                })
            except Exception as e:
                print(f"[prepare_metadata] Warning: could not parse {kfile}: {e}")

        out_df = pd.DataFrame(rows)
        out_df = out_df.sort_values(["country", "sample_id"])
        out_df.to_csv(output.metadata, sep="\t", index=False)
        print(f"[prepare_metadata] Compiled {len(rows)} samples -> {output.metadata}")


# =============================================================================
# RULE 1 - Prokka: Genome Annotation
# =============================================================================
rule prokka:
    input:
        contigs = CONTIGS_DIR
    output:
        gff = f"{OUT}/prokka/{{sample}}/{{sample}}.gff",
        faa = f"{OUT}/prokka/{{sample}}/{{sample}}.faa",
        txt = f"{OUT}/prokka/{{sample}}/{{sample}}.txt",
    log:
        "logs/downstream/prokka/{sample}.log"
    conda:
        "downstream/envs/prokka_roary.yaml"
    threads: 4
    resources:
        mem_mb = 4000
    params:
        outdir  = f"{OUT}/prokka/{{sample}}",
        kingdom = "Bacteria",
        genus   = "Klebsiella",
        species = "pneumoniae",
        extra   = "--centre HPC --compliant",
    shell:
        """
        prokka \
            --kingdom {params.kingdom} \
            --genus {params.genus} \
            --species {params.species} \
            --outdir {params.outdir} \
            --prefix {wildcards.sample} \
            --cpus {threads} \
            --force \
            {params.extra} \
            {input.contigs} \
            > {log} 2>&1
        """


# =============================================================================
# RULE 2 - FastANI: Average Nucleotide Identity (all-vs-all)
# =============================================================================
rule fastani_prepare:
    """Write a list file of all contig paths for FastANI."""
    input:
        expand(CONTIGS_DIR, sample=SAMPLES)
    output:
        query_list = f"{OUT}/fastani/query_list.txt"
    run:
        os.makedirs(f"{OUT}/fastani", exist_ok=True)
        with open(output.query_list, "w") as fh:
            for path in input:
                fh.write(path + "\n")


rule fastani_compute:
    input:
        query_list = f"{OUT}/fastani/query_list.txt"
    output:
        raw_tsv = f"{OUT}/fastani/ani_matrix.tsv"
    log:
        "logs/downstream/fastani/fastani.log"
    conda:
        "downstream/envs/fastani.yaml"
    threads: 16
    resources:
        mem_mb = 8000
    shell:
        """
        fastANI \
            --ql {input.query_list} \
            --rl {input.query_list} \
            --matrix \
            -t {threads} \
            -o {output.raw_tsv} \
            > {log} 2>&1
        """


rule fastani_classify:
    """Classify each sample: K. pneumoniae vs K. quasipneumoniae using ANI."""
    input:
        ani_tsv = f"{OUT}/fastani/ani_matrix.tsv",
        samples = SAMPLES_TSV,
    output:
        classified = f"{OUT}/fastani/ani_classified.tsv"
    run:
        import pandas as pd

        # FastANI --matrix output: square matrix with sample paths as row/col headers
        # Format: first row = header (paths), subsequent rows = sample + ANI values
        ani_lines = []
        with open(input.ani_tsv) as fh:
            header = fh.readline().strip().split("\t")
            for line in fh:
                parts = line.strip().split("\t")
                ani_lines.append(parts)

        # Extract sample labels from paths (last component without extension)
        def extract_id(path):
            return os.path.basename(path).replace("_contigs.fasta", "").replace("contigs.fasta", "")

        col_labels = [extract_id(h) for h in header[1:]]

        ani_df = pd.DataFrame(ani_lines, columns=["sample_path"] + col_labels)
        ani_df["sample_id"] = ani_df["sample_path"].apply(extract_id)
        ani_df = ani_df.set_index("sample_id").drop(columns=["sample_path"])
        ani_df = ani_df.apply(pd.to_numeric, errors="coerce")

        # Species classification:
        # Known K. pneumoniae samples from metadata (16 samples)
        # Known K. quasipneumoniae from metadata (4 samples: SRR31897979/80/81/82)
        # Use metadata if available, else fallback to ANI clustering
        samples_df = pd.read_csv(input.samples, sep="\t")
        species_map = {}
        if "species" in samples_df.columns:
            species_map = dict(zip(samples_df["sample_id"], samples_df["species"]))

        rows = []
        for sid in SAMPLES:
            sp = species_map.get(sid, "Klebsiella pneumoniae")
            rows.append({"sample_id": sid, "species_label": sp})

        out_df = pd.DataFrame(rows)
        out_df.to_csv(output.classified, sep="\t", index=False)
        print(f"[fastani_classify] Classified {len(rows)} samples.")


# =============================================================================
# RULE 3 - PlasmidFinder: Plasmid Replicon Typing
# =============================================================================
rule plasmidfinder_download_db:
    """Download PlasmidFinder database if not already present."""
    output:
        db_done = PLASMID_DB + "/.db_downloaded"
    conda:
        "downstream/envs/plasmid.yaml"
    shell:
        """
        mkdir -p {PLASMID_DB}
        # Try CGE download tool; fall back to git clone if unavailable
        if command -v download-db.sh &>/dev/null; then
            download-db.sh plasmidfinder {PLASMID_DB}
        else
            git clone https://bitbucket.org/genomicepidemiology/plasmidfinder_db.git {PLASMID_DB}/db
        fi
        touch {output.db_done}
        """


rule plasmidfinder:
    input:
        contigs  = CONTIGS_DIR,
        db_done  = PLASMID_DB + "/.db_downloaded",
    output:
        results_tab  = f"{OUT}/plasmid/{{sample}}/results_tab.tsv",
        results_json = f"{OUT}/plasmid/{{sample}}/data.json",
    log:
        "logs/downstream/plasmidfinder/{sample}.log"
    conda:
        "downstream/envs/plasmid.yaml"
    threads: 1
    resources:
        mem_mb = 2000
    params:
        outdir = f"{OUT}/plasmid/{{sample}}",
        db     = PLASMID_DB + "/db",
    shell:
        """
        mkdir -p {params.outdir}
        plasmidfinder.py \
            -i {input.contigs} \
            -o {params.outdir} \
            -p {params.db} \
            -x \
            > {log} 2>&1
        # Normalize output filename
        if [ -f {params.outdir}/results_tab.txt ]; then
            cp {params.outdir}/results_tab.txt {output.results_tab}
        else
            touch {output.results_tab}
        fi
        [ -f {params.outdir}/data.json ] || touch {output.results_json}
        """


rule plasmidfinder_summary:
    """Merge all PlasmidFinder results into a single table."""
    input:
        tabs = expand(f"{OUT}/plasmid/{{sample}}/results_tab.tsv", sample=SAMPLES)
    output:
        summary = f"{OUT}/plasmid/plasmid_summary.tsv"
    run:
        import pandas as pd
        frames = []
        for path, sample in zip(input.tabs, SAMPLES):
            try:
                df = pd.read_csv(path, sep="\t")
                if not df.empty and len(df.columns) > 1:
                    df.insert(0, "sample_id", sample)
                    frames.append(df)
            except Exception:
                pass
        if frames:
            result = pd.concat(frames, ignore_index=True)
        else:
            result = pd.DataFrame(
                columns=["sample_id", "Plasmid", "Identity", "Coverage", "Contig"]
            )
        result.to_csv(output.summary, sep="\t", index=False)
        print(f"[plasmidfinder_summary] {len(frames)} samples with plasmid hits.")


# =============================================================================
# RULE 4 - Roary: Pan-genome Analysis
# =============================================================================
rule roary:
    input:
        gffs = expand(f"{OUT}/prokka/{{sample}}/{{sample}}.gff", sample=SAMPLES)
    output:
        csv  = f"{OUT}/roary/gene_presence_absence.csv",
        txt  = f"{OUT}/roary/summary_statistics.txt",
        tree = f"{OUT}/roary/accessory_binary_genes.fa.newick",
    log:
        "logs/downstream/roary/roary.log"
    conda:
        "downstream/envs/prokka_roary.yaml"
    threads: 16
    resources:
        mem_mb = 16000
    params:
        outdir   = f"{OUT}/roary",
        identity = 95,
        extra    = "-e -n -r -v",
    shell:
        """
        roary \
            -p {threads} \
            -i {params.identity} \
            -f {params.outdir} \
            {params.extra} \
            {input.gffs} \
            > {log} 2>&1
        # Ensure output files exist even if Roary writes them with different names
        ls {params.outdir}/ >> {log} 2>&1
        [ -f {params.outdir}/summary_statistics.txt ] || \
            echo "Roary summary not found" > {output.txt}
        """


